@baseUrl = http://localhost:{{$dotenv PORT}}

### Get all posts
GET {{baseUrl}}/posts
Content-Type: application/json

### Get on post
GET {{baseUrl}}/posts/10
Content-Type: application/json

### Create post
POST {{baseUrl}}/posts
Content-Type: application/json
Authorization: Bearer {{$dotenv TOKEN}}

{
    "title": "Un nouveau sujet très bien",
    "content": "Je médite encore sur le contenu",
    "category_id": [3, 2]
}

### Update post
PATCH {{baseUrl}}/posts/1
Content-Type: application/json
Authorization: Bearer {{$dotenv TOKEN}}

{
    "title": "Un sujet bien",
    "content": "Je médite encore sur le contenu",
    "category_id": [1, 2]
}

### Delete post
DELETE {{baseUrl}}/posts/10
Content-Type: application/json
Authorization: Bearer {{$dotenv TOKEN}}
